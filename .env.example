# Database (used by PHP container)
DB_HOST=mysql
DB_NAME=webiartisan
DB_USER=webiartisan
DB_PASS=webiartisan_dev

# Security — generate a strong random secret (min 32 chars) for production
JWT_SECRET=change_me_in_production_to_a_random_string_of_at_least_32_chars

# Frontend (copy to sites/webiartisan-livry/.env)
VITE_API_URL=http://localhost:8080/api
VITE_CITY_SLUG=livry
VITE_CITY_NAME=Livry
VITE_CITY_LAT=49.1081
VITE_CITY_LNG=-0.7658
VITE_CITY_CP=14240
