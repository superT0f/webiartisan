# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=webiartisan
DB_USER=webiartisan
DB_PASS=
DB_CHARSET=utf8mb4

# JWT Secret (generate with: php -r "echo bin2hex(random_bytes(32));")
JWT_SECRET=

# Stripe (compte test: https://dashboard.stripe.com/test/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_CURRENCY=eur

# Stripe Subscription Price IDs (create in Stripe Dashboard > Products)
# Pro plan
PRO_MONTHLY_PRICE_ID=
PRO_YEARLY_PRICE_ID=
# Business plan
BUSINESS_MONTHLY_PRICE_ID=
BUSINESS_YEARLY_PRICE_ID=

# App
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# API (separate subdomain for production)
API_URL=http://localhost:8080/api

# Static Sites Output (where generated HTML files are written)
SITE_OUTPUT_DIR=../htdocs
SITE_BASE_URL=https://app.prigent.tech

# Mail (used for magic link codes)
MAIL_FROM=noreply@webiartisan.prigent.tech
FROM_NAME=WebIArtisan

# Cron trigger secret (used by cron-job.org to trigger the email worker)
# Generate with: php -r "echo bin2hex(random_bytes(32));"
CRON_SECRET=

# Master admin token — bypass authentication for emergency/support access.
# Must be exactly 300 hex characters (150 bytes). When provided as X-Artisan-Token,
# the API authenticates as the first artisan flagged is_admin = 1.
# Generate with: php -r "echo bin2hex(random_bytes(150));"
# Leave empty to disable. If set, must be 300 hex chars.
ADMIN_MASTER_TOKEN=

